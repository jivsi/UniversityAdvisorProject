@{
    ViewData["Title"] = "AI Advisor";
}

<div class="ai-advisor-page">
    <div class="ai-advisor-header">
        <div class="container">
            <h1>🤖 AI University Advisor</h1>
            <p style="margin-top: 12px; opacity: 0.9;">Ask me anything about living costs, tuition fees, city rent prices, food expenses, and student life!</p>
        </div>
    </div>

    <div class="container">
        <div class="ai-advisor-container">
            <div class="ai-chat-widget">
                <div class="chat-messages" id="chatMessages">
                    <div class="chat-message bot-message">
                        <p><strong>AI Advisor:</strong> Hello! I'm here to help you with questions about:</p>
                        <ul style="margin: 8px 0; padding-left: 20px;">
                            <li>Living costs in different cities</li>
                            <li>Tuition fees and financial planning</li>
                            <li>City rent prices</li>
                            <li>Food expenses</li>
                            <li>General student life advice</li>
                        </ul>
                        <p>What would you like to know?</p>
                    </div>
                </div>

                <form id="chatForm" class="chat-form">
                    <input type="text" id="chatInput" placeholder="Ask about costs, expenses, student life..." class="chat-input" />
                    <button type="submit" class="chat-send">Send</button>
                </form>
            </div>

            <div class="ai-suggestions">
                <h3>Suggested Questions</h3>
                <div class="suggestion-buttons">
                    <button class="suggestion-btn" onclick="askQuestion('What is the average monthly living cost for a student in Berlin?')">
                        💰 Living costs in Berlin
                    </button>
                    <button class="suggestion-btn" onclick="askQuestion('How much should I budget for food expenses as a student?')">
                        🍔 Food expenses budget
                    </button>
                    <button class="suggestion-btn" onclick="askQuestion('What are typical rent prices for student housing in Paris?')">
                        🏠 Rent prices in Paris
                    </button>
                    <button class="suggestion-btn" onclick="askQuestion('What is the average tuition fee for European universities?')">
                        📚 Tuition fees in Europe
                    </button>
                    <button class="suggestion-btn" onclick="askQuestion('What should I know about student life in European universities?')">
                        🎓 Student life tips
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const chatForm = document.getElementById('chatForm');
        const chatInput = document.getElementById('chatInput');
        const chatMessages = document.getElementById('chatMessages');

        function askQuestion(question) {
            chatInput.value = question;
            chatForm.dispatchEvent(new Event('submit'));
        }

        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            const message = chatInput.value.trim();
            if (!message) return;

            const userMessageDiv = document.createElement('div');
            userMessageDiv.className = 'chat-message user-message';
            userMessageDiv.innerHTML = `<p><strong>You:</strong> ${message}</p>`;
            chatMessages.appendChild(userMessageDiv);

            chatInput.value = '';
            chatMessages.scrollTop = chatMessages.scrollHeight;

            try {
                const response = await fetch('/AIAdvisor/SendMessage', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `message=${encodeURIComponent(message)}`
                });

                const data = await response.json();

                const botMessageDiv = document.createElement('div');
                botMessageDiv.className = 'chat-message bot-message';
                botMessageDiv.innerHTML = `<p><strong>AI Advisor:</strong> ${data.response}</p>`;
                chatMessages.appendChild(botMessageDiv);

                chatMessages.scrollTop = chatMessages.scrollHeight;
            } catch (error) {
                console.error('Chat error:', error);
                const errorDiv = document.createElement('div');
                errorDiv.className = 'chat-message bot-message';
                errorDiv.innerHTML = '<p><strong>AI Advisor:</strong> Sorry, I encountered an error. Please try again.</p>';
                chatMessages.appendChild(errorDiv);
            }
        });
    </script>
}

<style>
    .ai-advisor-page {
        background: #f8f9fa;
        min-height: calc(100vh - 200px);
    }

    .ai-advisor-header {
        background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%);
        color: white;
        padding: 60px 0;
        text-align: center;
    }

    .ai-advisor-header h1 {
        font-size: 36px;
        font-weight: 600;
    }

    .ai-advisor-container {
        max-width: 900px;
        margin: 40px auto;
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 32px;
    }

    .ai-chat-widget {
        background: white;
        padding: 24px;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        height: 600px;
    }

    .ai-suggestions {
        background: white;
        padding: 24px;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        height: fit-content;
    }

    .ai-suggestions h3 {
        font-size: 20px;
        margin-bottom: 16px;
        color: #1a1a1a;
    }

    .suggestion-buttons {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .suggestion-btn {
        background: #f8f9fa;
        border: 1px solid #e0e0e0;
        padding: 12px 16px;
        border-radius: 8px;
        text-align: left;
        cursor: pointer;
        transition: all 0.2s;
        font-size: 14px;
    }

    .suggestion-btn:hover {
        background: #e0e7ff;
        border-color: #2563eb;
        color: #2563eb;
    }

    @@media (max-width: 968px) {
        .ai-advisor-container {
            grid-template-columns: 1fr;
        }
    }
</style>

