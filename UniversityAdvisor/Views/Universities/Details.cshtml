@model University
@{
    ViewData["Title"] = Model.Name;
    var avgRating = Model.Ratings?.Any() == true ? Model.Ratings.Average(r => r.Score) : (double?)null;
    var ratingCount = Model.Ratings?.Count ?? 0;
}

<div class="university-details-premium">
    <!-- Hero Header -->
    <div class="university-header-premium">
        <div class="container">
            <div class="header-content-premium">
                <div class="university-logo-large-premium">
                    @if (!string.IsNullOrEmpty(Model.LogoUrl))
                    {
                        <img src="@Model.LogoUrl" alt="@Model.Name" />
                    }
                    else
                    {
                        <div class="logo-placeholder-large-premium">🎓</div>
                    }
                </div>
                <div class="header-info-premium">
                    <h1 class="university-name-premium">@Model.Name</h1>
                    <p class="location-premium">
                        <i class="fas fa-map-marker-alt me-2"></i>@Model.City, @Model.Country
                    </p>
                    @if (Model.FoundedYear.HasValue)
                    {
                        <p class="founded-premium">
                            <i class="fas fa-calendar me-2"></i>Founded in @Model.FoundedYear
                        </p>
                    }
                    <div class="header-actions-premium mt-3">
                        @if (!string.IsNullOrEmpty(Model.WebsiteUrl))
                        {
                            <a href="@Model.WebsiteUrl" target="_blank" class="btn-website-premium">
                                <i class="fas fa-external-link-alt me-2"></i>Visit Website
                            </a>
                        }
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <button class="btn-favorite-details-premium" data-university-id="@Model.Id">
                                <i class="far fa-heart me-2"></i>Save to Favorites
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container py-5">
        <div class="row">
            <!-- Main Content -->
            <div class="col-lg-8">
                <!-- About Section -->
                <section class="info-section-premium mb-4">
                    <h2 class="section-title-premium-details">
                        <i class="fas fa-info-circle me-2"></i>About
                    </h2>
                    <p class="description-text-premium">
                        @(string.IsNullOrEmpty(Model.Description) ? "No description available for this university." : Model.Description)
                    </p>
                    @if (!string.IsNullOrEmpty(Model.ProfessionsOffered))
                    {
                        <div class="professions-tags-premium mt-3">
                            <strong class="me-2">Fields of Study:</strong>
                            @foreach (var profession in Model.ProfessionsOffered.Split(',').Take(5))
                            {
                                <span class="profession-tag-premium">@profession.Trim()</span>
                            }
                        </div>
                    }
                </section>

                <!-- Quick Facts -->
                <section class="info-section-premium mb-4">
                    <h2 class="section-title-premium-details">
                        <i class="fas fa-chart-bar me-2"></i>Quick Facts
                    </h2>
                    <div class="facts-grid-premium">
                        <div class="fact-card-premium">
                            <div class="fact-icon-premium">💵</div>
                            <div class="fact-content-premium">
                                <h4>Annual Tuition</h4>
                                <p class="fact-value-premium">$@Model.TuitionFeeMin.ToString("N0") - $@Model.TuitionFeeMax.ToString("N0")</p>
                            </div>
                        </div>
                        <div class="fact-card-premium">
                            <div class="fact-icon-premium">🏠</div>
                            <div class="fact-content-premium">
                                <h4>Monthly Living Cost</h4>
                                <p class="fact-value-premium">$@Model.LivingCostMonthly.ToString("N0")</p>
                            </div>
                        </div>
                        @if (Model.AcceptanceRate.HasValue)
                        {
                            <div class="fact-card-premium">
                                <div class="fact-icon-premium">✓</div>
                                <div class="fact-content-premium">
                                    <h4>Acceptance Rate</h4>
                                    <p class="fact-value-premium">@Model.AcceptanceRate%</p>
                                </div>
                            </div>
                        }
                        @if (Model.StudentCount.HasValue)
                        {
                            <div class="fact-card-premium">
                                <div class="fact-icon-premium">👥</div>
                                <div class="fact-content-premium">
                                    <h4>Student Population</h4>
                                    <p class="fact-value-premium">@Model.StudentCount.Value.ToString("N0")</p>
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <!-- Programs Section -->
                <section class="info-section-premium">
                    <h2 class="section-title-premium-details">
                        <i class="fas fa-graduation-cap me-2"></i>Programs Offered (@Model.Programs.Count)
                    </h2>
                    @if (Model.Programs.Any())
                    {
                        <div class="programs-grid-premium">
                            @foreach (var program in Model.Programs.Take(10))
                            {
                                <div class="program-card-premium">
                                    <div class="program-header-premium">
                                        <h4>@program.Name</h4>
                                        <span class="program-type-badge-premium">@program.DegreeType</span>
                                    </div>
                                    <div class="program-meta-premium">
                                        @if (program.DurationYears.HasValue)
                                        {
                                            <span><i class="fas fa-clock me-1"></i>@program.DurationYears years</span>
                                        }
                                        <span><i class="fas fa-language me-1"></i>@program.Language</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(program.Description))
                                    {
                                        <p class="program-description-premium">@program.Description</p>
                                    }
                                </div>
                            }
                        </div>
                        @if (Model.Programs.Count > 10)
                        {
                            <p class="text-muted mt-3">
                                <i class="fas fa-info-circle me-2"></i>Showing 10 of @Model.Programs.Count programs
                            </p>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No programs listed yet.</p>
                    }
                </section>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Rating Card -->
                <div class="sidebar-card-premium mb-4">
                    <h3 class="sidebar-title-premium">
                        <i class="fas fa-star me-2"></i>Student Ratings
                    </h3>
                    @if (avgRating.HasValue)
                    {
                        var rounded = (int)Math.Round(avgRating.Value);
                        <div class="rating-display-premium">
                            <div class="rating-stars-premium">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="fas fa-star @(i <= rounded ? "text-warning" : "text-muted")"></i>
                                }
                            </div>
                            <p class="rating-value-premium">
                                <strong>@avgRating.Value.ToString("F1")</strong> out of 5
                                <span class="text-muted">(@ratingCount @(ratingCount == 1 ? "rating" : "ratings"))</span>
                            </p>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No ratings yet. Be the first to rate!</p>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Ratings" asp-action="Submit" method="post" class="rating-form-premium mt-4">
                            <input type="hidden" name="universityId" value="@Model.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <div class="mb-3">
                                <label class="form-label">Your Rating</label>
                                <select name="score" class="form-select" required>
                                    <option value="">Select rating...</option>
                                    <option value="5">5 - Excellent</option>
                                    <option value="4">4 - Good</option>
                                    <option value="3">3 - Average</option>
                                    <option value="2">2 - Poor</option>
                                    <option value="1">1 - Bad</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Comment (optional)</label>
                                <textarea name="comment" rows="3" class="form-control" placeholder="Share your experience..."></textarea>
                            </div>
                            <button type="submit" class="btn-submit-rating-premium w-100">
                                <i class="fas fa-paper-plane me-2"></i>Submit Rating
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn-login-link-premium">
                            <i class="fas fa-sign-in-alt me-2"></i>Log in to leave a rating
                        </a>
                    }

                    @if (Model.Ratings != null && Model.Ratings.Any())
                    {
                        <div class="ratings-list-premium mt-4">
                            <h5 class="mb-3">Recent Reviews</h5>
                            @foreach (var rating in Model.Ratings.OrderByDescending(r => r.CreatedAt).Take(5))
                            {
                                <div class="rating-item-premium">
                                    <div class="rating-item-header-premium">
                                        <div class="rating-stars-small-premium">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fas fa-star @(i <= rating.Score ? "text-warning" : "text-muted")" style="font-size: 0.75rem;"></i>
                                            }
                                        </div>
                                        <span class="rating-date-premium">@rating.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(rating.Comment))
                                    {
                                        <p class="rating-comment-premium">@rating.Comment</p>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- AI Chat Widget -->
                <div class="sidebar-card-premium mb-4">
                    <h3 class="sidebar-title-premium">
                        <i class="fas fa-robot me-2"></i>AI Assistant
                    </h3>
                    <p class="chat-intro-premium">Ask me anything about @Model.Name!</p>

                    <div class="chat-messages-premium" id="chatMessages">
                        <div class="chat-message-premium bot-message-premium">
                            <p>Hello! I can help you with information about tuition, programs, location, and more. What would you like to know?</p>
                        </div>
                    </div>

                    <form id="chatForm" class="chat-form-premium">
                        <input type="text" id="chatInput" placeholder="Ask about costs, programs, etc..." class="chat-input-premium" />
                        <button type="submit" class="chat-send-premium">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </form>
                </div>

                <!-- Quick Actions -->
                <div class="sidebar-card-premium">
                    <h3 class="sidebar-title-premium">
                        <i class="fas fa-bolt me-2"></i>Quick Actions
                    </h3>
                    <div class="quick-actions-premium">
                        <a asp-controller="Universities" asp-action="Search" class="quick-action-link-premium">
                            <i class="fas fa-search me-2"></i>Search More Universities
                        </a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Account" asp-action="Profile" class="quick-action-link-premium">
                                <i class="fas fa-user me-2"></i>View My Dashboard
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Register" class="quick-action-link-premium">
                                <i class="fas fa-user-plus me-2"></i>Create Account
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
