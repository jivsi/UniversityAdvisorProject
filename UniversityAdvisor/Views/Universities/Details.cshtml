@model University
@{
    ViewData["Title"] = Model.Name;
}

<div class="university-details">
    <div class="university-header">
        <div class="container">
            <div class="header-content">
                <div class="university-logo-large">
                    @if (!string.IsNullOrEmpty(Model.LogoUrl))
                    {
                        <img src="@Model.LogoUrl" alt="@Model.Name" />
                    }
                    else
                    {
                        <div class="logo-placeholder-large">🎓</div>
                    }
                </div>
                <div class="header-info">
                    <h1>@Model.Name</h1>
                    <p class="location">📍 @Model.City, @Model.Country</p>
                    @if (Model.FoundedYear.HasValue)
                    {
                        <p class="founded">Founded: @Model.FoundedYear</p>
                    }
                    @if (!string.IsNullOrEmpty(Model.WebsiteUrl))
                    {
                        <a href="@Model.WebsiteUrl" target="_blank" class="website-link">Visit Website →</a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="details-layout">
            <div class="details-main">
                <section class="info-section">
                    <h2>About</h2>
                    <p>@(string.IsNullOrEmpty(Model.Description) ? "No description available." : Model.Description)</p>
                    @if (!string.IsNullOrEmpty(Model.ProfessionsOffered))
                    {
                        <p><strong>Fields of Study:</strong> @Model.ProfessionsOffered</p>
                    }
                </section>

                <section class="info-section">
                    <h2>Quick Facts</h2>
                    <div class="facts-grid">
                        <div class="fact-card">
                            <div class="fact-icon">💵</div>
                            <div class="fact-content">
                                <h4>Annual Tuition</h4>
                                <p>$@Model.TuitionFeeMin.ToString("N0") - $@Model.TuitionFeeMax.ToString("N0")</p>
                            </div>
                        </div>
                        <div class="fact-card">
                            <div class="fact-icon">🏠</div>
                            <div class="fact-content">
                                <h4>Monthly Living Cost</h4>
                                <p>$@Model.LivingCostMonthly.ToString("N0")</p>
                            </div>
                        </div>
                        @if (Model.AcceptanceRate.HasValue)
                        {
                            <div class="fact-card">
                                <div class="fact-icon">✓</div>
                                <div class="fact-content">
                                    <h4>Acceptance Rate</h4>
                                    <p>@Model.AcceptanceRate%</p>
                                </div>
                            </div>
                        }
                        @if (Model.StudentCount.HasValue)
                        {
                            <div class="fact-card">
                                <div class="fact-icon">👥</div>
                                <div class="fact-content">
                                    <h4>Student Population</h4>
                                    <p>@Model.StudentCount.Value.ToString("N0")</p>
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <section class="info-section">
                    <h2>Programs Offered (@Model.Programs.Count)</h2>
                    @if (Model.Programs.Any())
                    {
                        <div class="programs-grid">
                            @foreach (var program in Model.Programs)
                            {
                                <div class="program-card">
                                    <h4>@program.Name</h4>
                                    <p class="program-type">@program.DegreeType</p>
                                    <p class="program-details">
                                        Duration: @program.DurationYears years | Language: @program.Language
                                    </p>
                                    @if (!string.IsNullOrEmpty(program.Description))
                                    {
                                        <p class="program-description">@program.Description</p>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p>No programs listed yet.</p>
                    }
                </section>
            </div>

            <aside class="details-sidebar">
                <div class="rating-card">
                    <h3>⭐ Student Ratings</h3>
                    @{
                        var avg = Model.Ratings != null && Model.Ratings.Any() ? Model.Ratings.Average(r => r.Score) : (double?)null;
                    }
                    @if (avg.HasValue)
                    {
                        var rounded = (int)Math.Round(avg.Value);
                        var stars = new string('★', rounded) + new string('☆', 5 - rounded);
                        <p><strong>Average:</strong> <span title="@avg.Value.ToString("0.0") out of 5">@stars (@avg.Value.ToString("0.0"))</span> (@Model.Ratings.Count ratings)</p>
                    }
                    else
                    {
                        <p>No ratings yet. Be the first to rate!</p>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Ratings" asp-action="Submit" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="universityId" value="@Model.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <div class="rating-input" style="margin-bottom: 12px;">
                                <label for="score" style="display: block; margin-bottom: 4px; font-weight: 500;">Your rating</label>
                                <select id="score" name="score" class="form-control" style="width: 100%;">
                                    <option value="5">5 - Excellent</option>
                                    <option value="4">4 - Good</option>
                                    <option value="3">3 - Average</option>
                                    <option value="2">2 - Poor</option>
                                    <option value="1">1 - Bad</option>
                                </select>
                            </div>
                            <div class="rating-comment" style="margin-bottom: 12px;">
                                <label for="comment" style="display: block; margin-bottom: 4px; font-weight: 500;">Comment (optional)</label>
                                <textarea id="comment" name="comment" rows="3" placeholder="Share your experience..." class="form-control" style="width: 100%;"></textarea>
                            </div>
                            <button type="submit" class="btn-favorite" style="width: 100%;">Submit Rating</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login">Log in to leave a rating</a>
                    }

                    @if (Model.Ratings != null && Model.Ratings.Any())
                    {
                        <div class="ratings-list" style="margin-top: 20px;">
                            <h4>Recent ratings</h4>
                            @foreach (var r in Model.Ratings.OrderByDescending(r => r.CreatedAt).Take(5))
                            {
                                <div class="rating-item" style="padding: 12px; background: #f8f9fa; border-radius: 8px; margin-bottom: 8px;">
                                    <div><strong>@r.Score/5</strong> <span style="color:#666">@r.CreatedAt.ToLocalTime().ToShortDateString()</span></div>
                                    @if (!string.IsNullOrWhiteSpace(r.Comment))
                                    {
                                        <div style="margin-top: 4px;">@r.Comment</div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="chat-widget">
                    <h3>🤖 AI Assistant</h3>
                    <p class="chat-intro">Ask me anything about @Model.Name!</p>

                    <div class="chat-messages" id="chatMessages">
                        <div class="chat-message bot-message">
                            <p>Hello! I can help you with information about tuition, programs, location, and more. What would you like to know?</p>
                        </div>
                    </div>

                    <form id="chatForm" class="chat-form">
                        <input type="text" id="chatInput" placeholder="Ask about costs, programs, etc..." class="chat-input" />
                        <button type="submit" class="chat-send">Send</button>
                    </form>
                </div>

                <div class="action-card">
                    <h4>Interested in this university?</h4>
                    <p>Save it to your favorites or learn more about the application process.</p>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button class="btn-favorite">Add to Favorites</button>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn-favorite">Sign Up to Save</a>
                    }
                </div>
            </aside>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const universityId = '@Model.Id';
        const chatForm = document.getElementById('chatForm');
        const chatInput = document.getElementById('chatInput');
        const chatMessages = document.getElementById('chatMessages');

        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            const message = chatInput.value.trim();
            if (!message) return;

            const userMessageDiv = document.createElement('div');
            userMessageDiv.className = 'chat-message user-message';
            userMessageDiv.innerHTML = `<p>${message}</p>`;
            chatMessages.appendChild(userMessageDiv);

            chatInput.value = '';
            chatMessages.scrollTop = chatMessages.scrollHeight;

            try {
                const response = await fetch('/Chat/SendMessage', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `message=${encodeURIComponent(message)}&universityId=${universityId}`
                });

                const data = await response.json();

                const botMessageDiv = document.createElement('div');
                botMessageDiv.className = 'chat-message bot-message';
                botMessageDiv.innerHTML = `<p>${data.response}</p>`;
                chatMessages.appendChild(botMessageDiv);

                chatMessages.scrollTop = chatMessages.scrollHeight;
            } catch (error) {
                console.error('Chat error:', error);
            }
        });
    </script>
}

