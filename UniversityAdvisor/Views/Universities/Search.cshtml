@model SearchViewModel
@{
    ViewData["Title"] = "Search Universities - Find Your Perfect Match";
}

<div class="search-page-premium">
    <!-- Search Header -->
    <div class="search-header-premium">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8 text-center">
                    <h1 class="search-title-premium">
                        <i class="fas fa-search me-3"></i>Find Your Perfect University
                    </h1>
                    <p class="search-subtitle-premium">
                        Search by profession, country, city, tuition cost, and more. Get personalized matches instantly.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="container py-5">
        <div class="row">
            <!-- Filters Sidebar -->
            <aside class="col-lg-3 mb-4">
                <div class="search-filters-premium">
                    <div class="filters-header">
                        <h3><i class="fas fa-filter me-2"></i>Refine Matches</h3>
                        <button class="btn-clear-filters" onclick="clearFilters()">
                            <i class="fas fa-times"></i> Clear All
                        </button>
                    </div>
                    
                    <form asp-controller="Universities" asp-action="Results" method="get" id="searchForm">
                        <div class="filter-group-premium">
                            <label class="filter-label">
                                <i class="fas fa-graduation-cap me-2"></i>Profession / Field
                            </label>
                            <input type="text" asp-for="Profession" placeholder="e.g., Computer Science" class="form-control filter-input-premium" />
                        </div>

                        <div class="filter-group-premium">
                            <label class="filter-label">
                                <i class="fas fa-university me-2"></i>University Name
                            </label>
                            <input type="text" asp-for="SearchQuery" placeholder="Search by name..." class="form-control filter-input-premium" />
                        </div>

                        <div class="filter-group-premium">
                            <label class="filter-label">
                                <i class="fas fa-globe me-2"></i>Country
                            </label>
                            <select asp-for="Country" class="form-select filter-select-premium" id="countrySelect">
                                <option value="">All Countries</option>
                                @if (Model?.Countries != null)
                                {
                                    @foreach (var country in Model.Countries)
                                    {
                                        <option value="@country" selected="@(country == Model.Country)">@country</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="filter-group-premium">
                            <label class="filter-label">
                                <i class="fas fa-map-marker-alt me-2"></i>City
                            </label>
                            <select asp-for="City" class="form-select filter-select-premium" id="citySelect">
                                <option value="">All Cities</option>
                            </select>
                        </div>

                        <div class="filter-group-premium">
                            <label class="filter-label">
                                <i class="fas fa-certificate me-2"></i>Degree Type
                            </label>
                            <select asp-for="DegreeType" class="form-select filter-select-premium">
                                <option value="">All Degrees</option>
                                <option value="Bachelor">Bachelor's</option>
                                <option value="Master">Master's</option>
                                <option value="PhD">PhD</option>
                            </select>
                        </div>

                        <div class="filter-group-premium">
                            <label class="filter-label">
                                <i class="fas fa-dollar-sign me-2"></i>Tuition Range (USD/year)
                            </label>
                            <div class="d-flex gap-2 align-items-center">
                                <input type="number" asp-for="MinTuition" placeholder="Min" class="form-control filter-input-small" />
                                <span class="text-muted">-</span>
                                <input type="number" asp-for="MaxTuition" placeholder="Max" class="form-control filter-input-small" />
                            </div>
                        </div>

                        <div class="filter-group-premium">
                            <label class="filter-label">
                                <i class="fas fa-sort me-2"></i>Sort By
                            </label>
                            <select asp-for="SortBy" class="form-select filter-select-premium">
                                <option value="name">Name (A-Z)</option>
                                <option value="tuition_asc">Tuition (Low to High)</option>
                                <option value="tuition_desc">Tuition (High to Low)</option>
                                <option value="acceptance">Acceptance Rate</option>
                                <option value="rating">Rating</option>
                            </select>
                        </div>

                        <button type="submit" class="btn-filter-premium w-100">
                            <i class="fas fa-search me-2"></i>Apply Filters
                        </button>
                    </form>
                </div>
            </aside>

            <!-- Results Area -->
            <div class="col-lg-9">
                <div class="search-results-premium">
                    <div class="results-header-premium">
                        <h2><i class="fas fa-lightbulb me-2"></i>Start Your Search</h2>
                        <p class="results-info-premium">
                            Use the filters on the left to find universities that match your criteria. Our AI will help you discover the perfect match!
                        </p>
                        <div class="alert alert-info mt-3" role="alert">
                            <i class="fas fa-info-circle me-2"></i>
                            <strong>Tip:</strong> If you don't see results, try searching with a country filter. The system will automatically import universities on your first search.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.search-page-premium {
    background: var(--light);
    min-height: calc(100vh - 200px);
}

.search-header-premium {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    padding: 4rem 0;
    margin-bottom: 0;
}

.search-title-premium {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    margin-bottom: 1rem;
}

.search-subtitle-premium {
    font-size: 1.25rem;
    opacity: 0.95;
}

.search-filters-premium {
    background: white;
    padding: 2rem;
    border-radius: 1.5rem;
    box-shadow: var(--shadow-lg);
    position: sticky;
    top: 100px;
}

[data-theme="dark"] .search-filters-premium {
    background: #1f2937;
}

.filters-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--border);
}

.filters-header h3 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--dark);
}

.btn-clear-filters {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--gray);
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.2s ease;
}

.btn-clear-filters:hover {
    background: var(--danger);
    color: white;
    border-color: var(--danger);
}

.filter-group-premium {
    margin-bottom: 1.5rem;
}

.filter-label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
    color: var(--dark);
    font-size: 0.95rem;
}

.filter-input-premium,
.filter-select-premium {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 2px solid var(--border);
    border-radius: 0.75rem;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    background: var(--light);
    color: var(--dark);
}

.filter-input-premium:focus,
.filter-select-premium:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

.filter-input-small {
    flex: 1;
    padding: 0.75rem;
    border: 2px solid var(--border);
    border-radius: 0.5rem;
    font-size: 0.9rem;
}

.btn-filter-premium {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    border: none;
    padding: 1rem;
    border-radius: 0.75rem;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
    margin-top: 1rem;
}

.btn-filter-premium:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(37, 99, 235, 0.4);
}

.search-results-premium {
    background: white;
    padding: 2.5rem;
    border-radius: 1.5rem;
    box-shadow: var(--shadow-lg);
    min-height: 500px;
}

[data-theme="dark"] .search-results-premium {
    background: #1f2937;
}

.results-header-premium h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--dark);
}

.results-info-premium {
    color: var(--gray);
    font-size: 1.05rem;
    line-height: 1.7;
}

@@media (max-width: 992px) {
    .search-filters-premium {
        position: relative;
        top: 0;
        margin-bottom: 2rem;
    }
}
</style>

@section Scripts {
    <script>
        // City dropdown population
        document.getElementById('countrySelect')?.addEventListener('change', async function() {
            const country = this.value;
            const citySelect = document.getElementById('citySelect');
            
            citySelect.innerHTML = '<option value="">Loading cities...</option>';
            citySelect.disabled = true;
            
            if (country) {
                try {
                    const response = await fetch(`/Universities/GetCities?country=${encodeURIComponent(country)}`);
                    const cities = await response.json();
                    
                    citySelect.innerHTML = '<option value="">All Cities</option>';
                    cities.forEach(city => {
                        const option = document.createElement('option');
                        option.value = city;
                        option.textContent = city;
                        citySelect.appendChild(option);
                    });
                } catch (error) {
                    console.error('Error loading cities:', error);
                    citySelect.innerHTML = '<option value="">Error loading cities</option>';
                }
            } else {
                citySelect.innerHTML = '<option value="">All Cities</option>';
            }
            
            citySelect.disabled = false;
        });
        
        function clearFilters() {
            document.getElementById('searchForm')?.reset();
            document.getElementById('citySelect').innerHTML = '<option value="">All Cities</option>';
        }
        
        // Animate filters on load
        if (typeof gsap !== 'undefined') {
            gsap.from('.search-filters-premium', {
                opacity: 0,
                x: -50,
                duration: 0.6,
                ease: 'power2.out'
            });
            
            gsap.from('.search-results-premium', {
                opacity: 0,
                x: 50,
                duration: 0.6,
                ease: 'power2.out',
                delay: 0.2
            });
        }
    </script>
}
