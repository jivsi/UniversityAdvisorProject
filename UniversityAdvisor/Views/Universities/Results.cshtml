@model SearchViewModel
@{
    ViewData["Title"] = $"Search Results - {Model.TotalResults} Universities Found";
}

<div class="search-page-premium">
    <!-- Results Header -->
    <div class="search-header-premium">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10 text-center">
                    <h1 class="search-title-premium">
                        <i class="fas fa-university me-3"></i>Search Results
                    </h1>
                    <p class="search-subtitle-premium">
                        Found <strong>@Model.TotalResults</strong> universities matching your criteria
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="container py-5">
        <div class="row">
            <!-- Filters Sidebar -->
            <aside class="col-lg-3 mb-4">
                <div class="search-filters-premium">
                    <div class="filters-header">
                        <h3><i class="fas fa-filter me-2"></i>Refine</h3>
                        <button class="btn-clear-filters" onclick="clearFilters()">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    
                    <form asp-controller="Universities" asp-action="Results" method="get">
                        <input type="hidden" name="profession" value="@Model.Profession" />
                        <input type="hidden" name="searchQuery" value="@Model.SearchQuery" />
                        <input type="hidden" name="country" value="@Model.Country" />
                        <input type="hidden" name="city" value="@Model.City" />
                        <input type="hidden" name="degreeType" value="@Model.DegreeType" />
                        <input type="hidden" name="minTuition" value="@Model.MinTuition" />
                        <input type="hidden" name="maxTuition" value="@Model.MaxTuition" />
                        <input type="hidden" name="sortBy" value="@Model.SortBy" />

                        <div class="filter-group-premium">
                            <label class="filter-label">Sort By</label>
                            <select name="sortBy" class="form-select filter-select-premium" onchange="this.form.submit()">
                                <option value="name" selected="@(Model.SortBy == "name")">Name (A-Z)</option>
                                <option value="tuition_asc" selected="@(Model.SortBy == "tuition_asc")">Tuition (Low to High)</option>
                                <option value="tuition_desc" selected="@(Model.SortBy == "tuition_desc")">Tuition (High to Low)</option>
                                <option value="acceptance" selected="@(Model.SortBy == "acceptance")">Acceptance Rate</option>
                                <option value="rating" selected="@(Model.SortBy == "rating")">Rating</option>
                            </select>
                        </div>
                    </form>
                </div>
            </aside>

            <!-- Results -->
            <div class="col-lg-9">
                <div class="search-results-premium">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger-premium">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <strong>Error:</strong> @ViewBag.ErrorMessage
                        </div>
                    }
                    
                    @if (ViewBag.InfoMessage != null)
                    {
                        <div class="alert alert-info-premium">
                            <i class="fas fa-info-circle me-2"></i>
                            @ViewBag.InfoMessage
                        </div>
                    }
                    
                    @if (ViewBag.WarningMessage != null)
                    {
                        <div class="alert alert-warning-premium">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            @ViewBag.WarningMessage
                        </div>
                    }

                    @if (Model.Results != null && Model.Results.Any())
                    {
                        <div class="results-header-premium mb-4">
                            <div class="d-flex justify-content-between align-items-center flex-wrap">
                                <div>
                                    <h2 class="mb-2">
                                        <i class="fas fa-graduation-cap me-2"></i>
                                        @Model.TotalResults Universities Found
                                    </h2>
                                    <p class="results-info-premium mb-0">
                                        Showing results for your search criteria
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="university-list-premium">
                            @foreach (var university in Model.Results)
                            {
                                var avgRating = Model.UniversityAverageRatings?.GetValueOrDefault(university.Id);
                                <div class="university-card-premium" data-university-id="@university.Id">
                                    <div class="university-logo-premium">
                                        @if (!string.IsNullOrEmpty(university.LogoUrl))
                                        {
                                            <img src="@university.LogoUrl" alt="@university.Name" />
                                        }
                                        else
                                        {
                                            <div class="logo-placeholder-premium">🎓</div>
                                        }
                                    </div>
                                    
                                    <div class="university-info-premium">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h3>
                                                <a asp-controller="Universities" asp-action="Details" asp-route-id="@university.Id" class="university-name-link">
                                                    @university.Name
                                                </a>
                                            </h3>
                                            @if (avgRating.HasValue)
                                            {
                                                <div class="rating-badge-premium">
                                                    <i class="fas fa-star text-warning"></i>
                                                    <span>@avgRating.Value.ToString("F1")</span>
                                                </div>
                                            }
                                        </div>
                                        
                                        <p class="university-location-premium mb-2">
                                            <i class="fas fa-map-marker-alt me-2 text-primary"></i>
                                            @university.City, @university.Country
                                        </p>
                                        
                                        @if (!string.IsNullOrEmpty(university.Description))
                                        {
                                            <p class="university-description-premium">
                                                @(university.Description.Length > 200 ? university.Description.Substring(0, 200) + "..." : university.Description)
                                            </p>
                                        }
                                        
                                        <div class="university-meta-premium">
                                            <div class="meta-item">
                                                <i class="fas fa-dollar-sign text-success"></i>
                                                <span>$@university.TuitionFeeMin.ToString("N0") - $@university.TuitionFeeMax.ToString("N0")/year</span>
                                            </div>
                                            <div class="meta-item">
                                                <i class="fas fa-book text-primary"></i>
                                                <span>@university.Programs.Count Programs</span>
                                            </div>
                                            @if (university.AcceptanceRate.HasValue)
                                            {
                                                <div class="meta-item">
                                                    <i class="fas fa-percent text-info"></i>
                                                    <span>@university.AcceptanceRate% Acceptance</span>
                                                </div>
                                            }
                                        </div>
                                        
                                        <div class="university-actions-premium mt-3">
                                            <a asp-controller="Universities" asp-action="Details" asp-route-id="@university.Id" class="btn-view-premium">
                                                <i class="fas fa-eye me-2"></i>View Details
                                            </a>
                                            @if (User.Identity?.IsAuthenticated == true)
                                            {
                                                <button class="btn-favorite-premium" data-university-id="@university.Id">
                                                    <i class="far fa-heart me-2"></i>Save
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="no-results-premium text-center py-5">
                            <div class="no-results-icon mb-4">
                                <i class="fas fa-search" style="font-size: 4rem; color: var(--gray);"></i>
                            </div>
                            <h3>No Universities Found</h3>
                            <p class="text-muted mb-4">
                                Try adjusting your search filters or search criteria to find more results.
                            </p>
                            <a asp-controller="Universities" asp-action="Search" class="btn-primary-premium">
                                <i class="fas fa-redo me-2"></i>Start New Search
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.alert-danger-premium {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #dc2626;
    padding: 1rem 1.5rem;
    border-radius: 0.75rem;
    margin-bottom: 1.5rem;
}

.alert-info-premium {
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    color: #1e40af;
    padding: 1rem 1.5rem;
    border-radius: 0.75rem;
    margin-bottom: 1.5rem;
}

.alert-warning-premium {
    background: #fffbeb;
    border: 1px solid #fde68a;
    color: #92400e;
    padding: 1rem 1.5rem;
    border-radius: 0.75rem;
    margin-bottom: 1.5rem;
}

.university-list-premium {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.university-card-premium {
    background: white;
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    gap: 1.5rem;
    transition: all 0.3s ease;
    box-shadow: var(--shadow);
}

[data-theme="dark"] .university-card-premium {
    background: #1f2937;
    border-color: var(--border);
}

.university-card-premium:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
    border-color: var(--primary);
}

.university-logo-premium {
    flex-shrink: 0;
    width: 120px;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--light);
    border-radius: 0.75rem;
    overflow: hidden;
}

.university-logo-premium img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.5rem;
}

.logo-placeholder-premium {
    font-size: 4rem;
    opacity: 0.5;
}

.university-info-premium {
    flex: 1;
}

.university-name-link {
    color: var(--dark);
    text-decoration: none;
    font-size: 1.5rem;
    font-weight: 700;
    transition: color 0.2s ease;
}

.university-name-link:hover {
    color: var(--primary);
}

.rating-badge-premium {
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-weight: 700;
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
}

.university-location-premium {
    color: var(--gray);
    font-size: 1rem;
    margin: 0;
}

.university-description-premium {
    color: var(--gray);
    line-height: 1.6;
    margin: 1rem 0;
}

.university-meta-premium {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin: 1rem 0;
}

.meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--gray);
    font-size: 0.95rem;
}

.university-actions-premium {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}

.btn-view-premium {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
}

.btn-view-premium:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(37, 99, 235, 0.4);
    color: white;
}

.btn-favorite-premium {
    background: transparent;
    border: 2px solid var(--secondary);
    color: var(--secondary);
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
}

.btn-favorite-premium:hover {
    background: var(--secondary);
    color: white;
    transform: translateY(-2px);
}

.no-results-premium {
    padding: 4rem 2rem;
}

.no-results-premium h3 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--dark);
}

@@media (max-width: 768px) {
    .university-card-premium {
        flex-direction: column;
    }
    
    .university-logo-premium {
        width: 100%;
        height: 200px;
    }
    
    .university-meta-premium {
        flex-direction: column;
        gap: 0.75rem;
    }
}
</style>

@section Scripts {
    <script>
        // Animate cards on load
        if (typeof gsap !== 'undefined') {
            gsap.utils.toArray('.university-card-premium').forEach((card, i) => {
                gsap.from(card, {
                    scrollTrigger: {
                        trigger: card,
                        start: 'top 85%',
                        toggleActions: 'play none none none'
                    },
                    opacity: 0,
                    y: 30,
                    duration: 0.5,
                    delay: i * 0.05,
                    ease: 'power2.out'
                });
            });
        }
        
        // Favorite button functionality
        document.querySelectorAll('.btn-favorite-premium').forEach(btn => {
            btn.addEventListener('click', function() {
                const icon = this.querySelector('i');
                if (icon.classList.contains('far')) {
                    icon.classList.remove('far');
                    icon.classList.add('fas');
                    this.style.background = 'var(--secondary)';
                    this.style.color = 'white';
                    this.style.borderColor = 'var(--secondary)';
                } else {
                    icon.classList.remove('fas');
                    icon.classList.add('far');
                    this.style.background = 'transparent';
                    this.style.color = 'var(--secondary)';
                }
            });
        });
        
        function clearFilters() {
            window.location.href = '/Universities/Search';
        }
    </script>
}
