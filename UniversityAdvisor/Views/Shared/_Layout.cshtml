<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - University Advisor</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <!-- Tailwind CSS via CDN (for quick prototyping, can be replaced with build process) -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        :root {
            --primary: #2563eb;
            --primary-dark: #1e40af;
            --secondary: #10b981;
            --accent: #f59e0b;
            --dark: #1a1a1a;
            --light: #f8f9fa;
            --gray: #6b7280;
            --border: #e5e7eb;
        }
        
        [data-theme="dark"] {
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --dark: #f8f9fa;
            --light: #1a1a1a;
            --gray: #9ca3af;
            --border: #374151;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        
        .gradient-text {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
    </style>
</head>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100">
    <!-- Navigation -->
    <nav class="navbar-modern fixed-top">
        <div class="container-fluid px-4">
            <div class="d-flex justify-content-between align-items-center w-100">
                <a asp-controller="Home" asp-action="Index" class="navbar-brand-modern">
                    <span class="logo-icon-modern">🎓</span>
                    <span class="logo-text-modern">University Advisor</span>
                </a>
                
                <div class="d-flex align-items-center gap-4">
                    <a asp-controller="Home" asp-action="Index" class="nav-link-modern">Home</a>
                    <a asp-controller="Universities" asp-action="Search" class="nav-link-modern">Search</a>
                    <a asp-controller="AIAdvisor" asp-action="Index" class="nav-link-modern">AI Advisor</a>
                    
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Account" asp-action="Profile" class="nav-link-modern">
                            <i class="fas fa-user-circle me-1"></i> Dashboard
                        </a>
                        <button id="themeToggle" class="btn-theme-toggle" aria-label="Toggle theme">
                            <i class="fas fa-moon"></i>
                        </button>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn-logout-modern">
                                <i class="fas fa-sign-out-alt me-1"></i> Logout
                            </button>
                        </form>
                    }
                    else
                    {
                        <button id="themeToggle" class="btn-theme-toggle" aria-label="Toggle theme">
                            <i class="fas fa-moon"></i>
                        </button>
                        <a asp-controller="Account" asp-action="Login" class="btn-login-modern">
                            <i class="fas fa-sign-in-alt me-1"></i> Login
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main style="margin-top: 80px;">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer-modern mt-5">
        <div class="container py-5">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5 class="mb-3">
                        <span class="logo-icon-modern">🎓</span> University Advisor
                    </h5>
                    <p class="text-muted">Your trusted partner in finding the perfect university for your future.</p>
                </div>
                <div class="col-md-2 mb-4">
                    <h6 class="mb-3">Explore</h6>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Universities" asp-action="Search" class="footer-link">Search</a></li>
                        <li><a asp-controller="AIAdvisor" asp-action="Index" class="footer-link">AI Advisor</a></li>
                        <li><a asp-controller="Home" asp-action="Index" class="footer-link">About</a></li>
                    </ul>
                </div>
                <div class="col-md-2 mb-4">
                    <h6 class="mb-3">Account</h6>
                    <ul class="list-unstyled">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li><a asp-controller="Account" asp-action="Profile" class="footer-link">Dashboard</a></li>
                            <li><a asp-controller="Account" asp-action="Logout" class="footer-link">Logout</a></li>
                        }
                        else
                        {
                            <li><a asp-controller="Account" asp-action="Login" class="footer-link">Login</a></li>
                            <li><a asp-controller="Account" asp-action="Register" class="footer-link">Sign Up</a></li>
                        }
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <h6 class="mb-3">Connect</h6>
                    <div class="social-links">
                        <a href="#" class="social-link"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="social-link"><i class="fab fa-facebook"></i></a>
                        <a href="#" class="social-link"><i class="fab fa-linkedin"></i></a>
                        <a href="#" class="social-link"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
            </div>
            <hr class="my-4">
            <div class="text-center text-muted">
                <p class="mb-0">&copy; 2025 University Advisor. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    
    <!-- GSAP for animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    
    <!-- Custom JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        // Dark mode toggle
        const themeToggle = document.getElementById('themeToggle');
        const html = document.documentElement;
        
        // Load saved theme
        const savedTheme = localStorage.getItem('theme') || 'light';
        html.setAttribute('data-theme', savedTheme);
        updateThemeIcon(savedTheme);
        
        themeToggle?.addEventListener('click', () => {
            const currentTheme = html.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateThemeIcon(newTheme);
        });
        
        function updateThemeIcon(theme) {
            const icon = themeToggle?.querySelector('i');
            if (icon) {
                icon.className = theme === 'dark' ? 'fas fa-sun' : 'fas fa-moon';
            }
        }
        
        // Register GSAP ScrollTrigger plugin
        if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
            gsap.registerPlugin(ScrollTrigger);
        }
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
