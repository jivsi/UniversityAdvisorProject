@model List<UniversityFinder.Models.University>
@{
    ViewData["Title"] = "All Universities";
}

<div class="container">
    <h2 class="mb-4">All Universities</h2>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var university in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">
                                <a asp-action="Details" asp-route-id="@university.Id" class="text-decoration-none">
                                    @university.Name
                                </a>
                                @if (!string.IsNullOrEmpty(university.Acronym))
                                {
                                    <small class="text-muted">(@university.Acronym)</small>
                                }
                            </h5>
                            <p class="card-text">
                                <i class="bi bi-geo-alt"></i> @university.City.Name, @university.Country.Name
                            </p>
                            <a asp-action="Details" asp-route-id="@university.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <h5>No universities found</h5>
            <p>Universities will appear here once they are synced from the HEI API.</p>
        </div>
    }
</div>

